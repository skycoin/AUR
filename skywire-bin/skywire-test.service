[Unit]
Description=Skywire (Test Deployment)
Wants=network-online.target

[Service]
Environment="GODEBUG=madvdontneed=1"
Type=simple
Environment="SYSTEMDCHILD=1"
ExecStart=/usr/bin/skywire visor -c /opt/skywire/skywire-test.json -ps -q http --loglvl debug
Restart=always
RestartSec=20
TimeoutSec=30
MemoryMax=80%

[Install]
WantedBy=multi-user.target
