#!/bin/bash
# /usr/bin/skywire-update
# Skywire auto-updater: builds as unprivileged user, installs as root
set -e

# Source configuration from /etc/skywire.conf if it exists
SKYENV=${SKYENV:-/etc/skywire.conf}
[[ -f "$SKYENV" ]] && source "$SKYENV"

# UPDATE_CHANNEL controls what to install:
#   "stable"        = latest CI-tested commit (default)
#   "develop"       = latest develop branch commit
#   "latest"        = latest tagged release version
#   "<commit-hash>" = pin to a specific commit
UPDATE_CHANNEL=${UPDATE_CHANNEL:-stable}

# GOPROXY_MODE controls Go module proxy behavior:
#   ""          = use default (proxy.golang.org)
#   "direct"    = bypass proxy, fetch directly from git (faster for latest commits)
GOPROXY_MODE=${GOPROXY_MODE:-}

BUILD_USER="skywire-build"
BUILD_HOME="/var/lib/${BUILD_USER}"
BUILD_GOPATH="${BUILD_HOME}/go"
BUILD_GOCACHE="${BUILD_HOME}/.cache/go-build"

# Ensure build user exists
if ! id "$BUILD_USER" &>/dev/null; then
    echo "Build user $BUILD_USER does not exist. Run: useradd -r -m -d $BUILD_HOME -s /usr/sbin/nologin $BUILD_USER"
    exit 1
fi

# Resolve the target commit
case "$UPDATE_CHANNEL" in
  stable)
    _tmpdir=$(mktemp -d)
    chown "$BUILD_USER:" "$_tmpdir"
    # GOPROXY=direct on the branch-tip resolver: proxy.golang.org
    # caches branch-tip → SHA resolutions for up to 30 min. Without
    # this, a fresh CI promotion to skywire-commit can be invisible
    # for half an hour and the update silently no-ops in ~250ms with
    # exit 0. See: AUTO_UPDATE.md "Why GOPROXY=direct?".
    TARGET=$(runuser -u "$BUILD_USER" -- env GOPATH="$BUILD_GOPATH" GOCACHE="$_tmpdir" GOPROXY=direct \
        go run github.com/skycoin/skywire/cmd/skywire-commit@skywire-commit 2>/dev/null || echo "")
    rm -rf "$_tmpdir"
    if [ -z "$TARGET" ]; then
        echo "Failed to fetch latest tested commit"
        exit 1
    fi
    ;;
  develop)
    TARGET="develop"
    ;;
  latest)
    TARGET="latest"
    ;;
  *)
    TARGET="$UPDATE_CHANNEL"
    ;;
esac

# Check if update is needed by querying the Go module proxy.
# Capture the full version string so the comparison handles BOTH
# pseudo-versions (v1.3.53-0.20260512235804-116448e5c2c0, develop tip)
# AND clean tags (v1.3.53, after a release). The previous regex-only
# extraction returned "none" on clean tags and broke the early-exit
# path, causing a restart every cycle even on no-op updates.
CURRENT=$(skywire -b 2>/dev/null | head -1 | tr -d '[:space:]' || echo "none")
[ -z "$CURRENT" ] && CURRENT="none"

# Resolve branch/tag to a commit. GOPROXY=direct by default — see
# the "stable" path above for the rationale. Operators can opt OUT
# (cache-on) by setting GOPROXY_MODE=proxy in /etc/skywire.conf
# when they specifically want proxy.golang.org's cached results.
if [ "$TARGET" = "develop" ] || [ "$TARGET" = "latest" ]; then
    _goproxy_env="GOPROXY=direct"
    [ "$GOPROXY_MODE" = "proxy" ] && _goproxy_env=""
    # Run as BUILD_USER with proper GOPATH/GOCACHE. Previously this
    # ran as root with no GOPATH, which caused `go list -m -json` to
    # fail silently (2>/dev/null swallows the error), leaving
    # PROXY_VERSION empty. The early-exit was then skipped and the
    # install + restart fired every cycle even when develop HEAD was
    # unchanged — visible as repeated "Updating: <hash> -> develop"
    # log lines with the same hash on each side of the arrow.
    PROXY_VERSION=$(runuser -u "$BUILD_USER" -- env \
        GOPATH="$BUILD_GOPATH" GOCACHE="$BUILD_GOCACHE" $_goproxy_env \
        go list -m -json "github.com/skycoin/skywire@${TARGET}" 2>/dev/null \
        | grep -oP '"Version":\s*"v[^"]*-\K[a-f0-9]+' || echo "")
    if [ -n "$PROXY_VERSION" ] && [ "$PROXY_VERSION" = "$CURRENT" ]; then
        echo "Skywire is up to date at $CURRENT"
        exit 0
    fi
fi

SHORT=${TARGET:0:12}
echo "Updating skywire ($UPDATE_CHANNEL): $CURRENT -> $SHORT"

# Build as unprivileged user. Branch-tip targets (develop/latest)
# need GOPROXY=direct for the same reason as the resolver above;
# pinned-SHA targets ($UPDATE_CHANNEL=<sha>) work with either since
# content-addressed module fetches are deterministic. Default on
# for safety; GOPROXY_MODE=proxy opts back to cached resolution.
_goproxy_build="GOPROXY=direct"
[ "$GOPROXY_MODE" = "proxy" ] && _goproxy_build=""
runuser -u "$BUILD_USER" -- env \
    GOPATH="$BUILD_GOPATH" \
    GOCACHE="$BUILD_GOCACHE" \
    GOFLAGS=-trimpath \
    $_goproxy_build \
    go install "github.com/skycoin/skywire@${TARGET}"

# Defense in depth: even if the early-exit above missed the no-op
# case (network glitch on the resolver, regex drift, etc.), don't
# install + restart when the freshly-built binary reports the same
# version as what's running. Compare full version strings so this
# works on both pseudo-versions and clean tags — same shape as the
# CURRENT extraction above.
NEW=$("${BUILD_GOPATH}/bin/skywire" -b 2>/dev/null | head -1 | tr -d '[:space:]' || echo "")
if [ -n "$NEW" ] && [ "$NEW" = "$CURRENT" ]; then
    echo "Build produced no version change (still $CURRENT) — skipping install + restart"
    exit 0
fi

# Install as root
install -Dm755 "${BUILD_GOPATH}/bin/skywire" /opt/skywire/bin/skywire

echo "Skywire updated to $SHORT"

# Run autoconfig and restart if running via systemd
if systemctl is-active --quiet skywire 2>/dev/null; then
    echo "Running autoconfig and restarting skywire..."
    skywire autoconfig 2>/dev/null || skywire-autoconfig 2>/dev/null || true
    systemctl restart skywire
fi
